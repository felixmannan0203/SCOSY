{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/pages/(.*)", "dest": "/pages/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/pwa/(.*)", "dest": "/pwa/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
